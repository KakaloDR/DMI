<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <connectionStrings>
    <!-- Conexión Local (Recomendado para pruebas locales con SQL Express) -->
    <add name="GDM_Connection" 
         connectionString="Server=localhost\SQLEXPRESS;Database=GDM_DB;Integrated Security=True;Encrypt=True;TrustServerCertificate=True;" 
         providerName="Microsoft.Data.SqlClient" />
         
    <!-- Conexión Remota (Servidor Ubuntu vía Tailscale VPN)
    <add name="GDM_Connection_Remote" 
         connectionString="Server=100.100.100.100,1433;Database=GDM_DB;User Id=sa;Password=YourSecurePassword123;Encrypt=True;TrustServerCertificate=True;" 
         providerName="Microsoft.Data.SqlClient" />
    -->
  </connectionStrings>
</configuration>
